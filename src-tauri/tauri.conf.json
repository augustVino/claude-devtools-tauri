{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "claude-devtools-tauri",
  "version": "0.1.0",
  "identifier": "com.augustvino.claude-devtools-tauri",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "visible": false,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 16, "y": 18 },
        "backgroundColor": "#1a1a1a",
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "shortDescription": "Visualize Claude Code session execution",
    "longDescription": "A lightweight desktop app for browsing, searching, and analyzing Claude Code sessions.",
    "copyright": "Copyright © 2025-2026 augustVino"
  }
}
